# EditorConfig: https://editorconfig.org
# Maintains consistent coding styles across editors and IDEs.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
quote_type = double

[Makefile]
indent_style = tab

[*.{json,lock}]
insert_final_newline = true
